{
  "name": "@bililive-tools/stream-get",
  "version": "0.2.0",
  "description": "parse live stream url",
  "main": "./lib/index.js",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "development": "./src/index.ts",
      "default": "./lib/index.js"
    },
    "./*.js": {
      "types": "./src/*.ts",
      "development": "./src/*.ts",
      "default": "./lib/*.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "manual-test": "vitest run"
  },
  "files": [
    "lib"
  ],
  "keywords": [
    "bililive-tools",
    "stream",
    "url",
    "parser"
  ],
  "repository": "https://github.com/renmu123/biliLive-tools",
  "author": "renmu123",
  "license": "MIT",
  "dependencies": {
    "cookie": "^1.1.1",
    "lodash-es": "catalog:",
    "safe-eval": "^0.4.1",
    "undici": "^7.24.0",
    "xhshow-js": "^1.0.0"
  },
  "devDependencies": {
    "@types/cookie": "^1.0.0"
  }
}
